<Window x:Class="VerteMarkPackager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VerteMarkPackager"
        mc:Ignorable="d"
        Title="VerteMarkPackager" Height="500" Width="800">
    <DockPanel>

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Návod" Click="HelpMenuItem_Click"/>
            <!--<MenuItem Header="Informace" Click="InfoMenuItem_Click"/>-->
            <MenuItem Header="Nahlásit problém" Click="ReportItem_Click"/>
            <MenuItem Header="O aplikaci" Click="AboutItem_Click"/>
        </Menu>

        <Canvas Margin="30, 15">

            <TextBlock HorizontalAlignment="Left" Canvas.Left="576" Canvas.Top="58" VerticalAlignment="Center">3.0</TextBlock>
            <TextBlock HorizontalAlignment="Left" FontSize="45" Grid.ColumnSpan="2" Canvas.Left="163" Canvas.Top="12" FontWeight="Bold">VerteMarkPackager</TextBlock>

            <!-- DICOM Files Directory Selection -->
            <TextBlock VerticalAlignment="Center" FontSize="16" Padding="0" Height="24" Canvas.Left="6" Canvas.Top="144">Adresář s DICOM soubory:</TextBlock>
            <TextBox x:Name="DicomFilesDirectoryTextBox" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Height="30" Canvas.Left="204" Canvas.Top="142" HorizontalAlignment="Left" Width="396"/>
            <Button Grid.Column="1" Grid.Row="1" Content="Procházet" VerticalAlignment="Top" Click="OnBrowseDicomFilesDirectory" Height="30" Canvas.Left="624" Canvas.Top="142" HorizontalAlignment="Left"/>

            <!-- Save Directory Selection -->
            <TextBlock VerticalAlignment="Center" Height="24" Padding="0" Canvas.Left="50" FontSize="16" Canvas.Top="199" HorizontalAlignment="Center">Adresář pro uložení:</TextBlock>
            <TextBox x:Name="SaveDirectoryTextBox" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Height="30" Canvas.Left="204" Canvas.Top="195" HorizontalAlignment="Left" Width="396"/>
            <Button Grid.Row="2" Grid.Column="1" Content="Procházet" VerticalAlignment="Center" Click="OnBrowseSaveDirectory" Height="30" Canvas.Left="624" Canvas.Top="195" HorizontalAlignment="Left"/>

            <!-- DICOM Files Count Slider -->
            <TextBlock VerticalAlignment="Top" Height="24" FontSize="16" Canvas.Left="26" Canvas.Top="255">Počet DICOM ve složce:</TextBlock>
            <Slider x:Name="DicomFilesCountSlider" Minimum="1" Maximum="50" Value="20" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Top" ValueChanged="DicomFilesCountSlider_ValueChanged" Height="30" Width="396" Padding="0" Canvas.Left="204" Canvas.Top="252" HorizontalAlignment="Center"/>
            <TextBox x:Name="DicomFilesCountTextBox" VerticalAlignment="Center" Text="20" TextChanged="OnDicomFilesCountTextChanged" Height="20" Width="34" Padding="0" Canvas.Left="624" Canvas.Top="256" HorizontalAlignment="Center" TextAlignment="Center"/>
            <!-- Create Button -->
            <Button x:Name="CreateButton" Grid.Row="4" Grid.Column="0" Content="Vytvořit!" VerticalAlignment="Top" HorizontalAlignment="Left" Width="149" Click="OnCreateButtonClick" Height="50" Canvas.Left="296" Canvas.Top="310" FontSize="14" Padding="0"/>

            <!-- ProgressBar -->
            <ProgressBar x:Name="ProgressBar" Grid.Row="4" Grid.Column="0" Margin="100,0,0,0" Height="20" Minimum="0" Maximum="100" Visibility="Collapsed"/>
        </Canvas>
    </DockPanel>
</Window>
